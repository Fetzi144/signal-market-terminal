# Core
DATABASE_URL=postgresql+asyncpg://smt:smt@db:5432/smt
LOG_LEVEL=INFO
LOG_FORMAT=text
API_KEY=

# Keep the micro focused on headless scanning.
KALSHI_ENABLED=false
WHALE_TRACKING_ENABLED=false
WORKER_METRICS_ENABLED=false

# Slow the cadence down and sample fewer books to fit a 1 GB VM.
MARKET_DISCOVERY_INTERVAL_SECONDS=900
SNAPSHOT_INTERVAL_SECONDS=300
EVALUATION_INTERVAL_SECONDS=900
ORDERBOOK_SAMPLE_SIZE=8
MIN_VOLUME_24H=10000

# Retention trimmed for small-disk free tier boxes.
RETENTION_PRICE_SNAPSHOTS_DAYS=7
RETENTION_ORDERBOOK_SNAPSHOTS_DAYS=3
RETENTION_SIGNALS_DAYS=30

# Heavy Polymarket phases off.
POLYMARKET_STREAM_ENABLED=false
POLYMARKET_META_SYNC_ENABLED=false
POLYMARKET_RAW_STORAGE_ENABLED=false
POLYMARKET_BOOK_RECON_ENABLED=false
POLYMARKET_FEATURES_ENABLED=false
POLYMARKET_STRUCTURE_ENGINE_ENABLED=false
POLYMARKET_RISK_GRAPH_ENABLED=false
POLYMARKET_PORTFOLIO_OPTIMIZER_ENABLED=false
POLYMARKET_REPLAY_ENABLED=false
POLYMARKET_USER_STREAM_ENABLED=false
POLYMARKET_LIVE_TRADING_ENABLED=false
POLYMARKET_PILOT_ENABLED=false
POLYMARKET_HEARTBEAT_ENABLED=false

# Alerts
ALERT_RANK_THRESHOLD=0.7
ALERT_WEBHOOK_URL=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_DISCORD_WEBHOOK_URL=

# Optional local API access when you start the backend profile.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
