# Database
DATABASE_URL=postgresql+asyncpg://smt:smt@localhost:5432/smt

# Polymarket API
POLYMARKET_API_BASE=https://clob.polymarket.com
POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
POLYMARKET_STREAM_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Kalshi API
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_ENABLED=true

# Connector
CONNECTOR_TIMEOUT_SECONDS=30.0

# Ingestion
SNAPSHOT_INTERVAL_SECONDS=120
MARKET_DISCOVERY_INTERVAL_SECONDS=300
MIN_VOLUME_24H=5000
POLYMARKET_STREAM_ENABLED=false
POLYMARKET_RESYNC_ON_STARTUP=true
POLYMARKET_STREAM_RECONNECT_BASE_SECONDS=1.0
POLYMARKET_STREAM_RECONNECT_MAX_SECONDS=30.0
POLYMARKET_STREAM_PING_INTERVAL_SECONDS=10
POLYMARKET_WATCH_RECONCILE_INTERVAL_SECONDS=30
POLYMARKET_GAP_SUSPECT_AFTER_SECONDS=30
POLYMARKET_MALFORMED_BURST_THRESHOLD=5
POLYMARKET_MALFORMED_BURST_WINDOW_SECONDS=30
POLYMARKET_NORMALIZATION_ENABLED=true
POLYMARKET_WATCH_BOOTSTRAP_FROM_ACTIVE_UNIVERSE=true
POLYMARKET_META_SYNC_ENABLED=false
POLYMARKET_META_SYNC_ON_STARTUP=true
POLYMARKET_META_SYNC_INTERVAL_SECONDS=900
POLYMARKET_META_SYNC_INCLUDE_CLOSED=false
POLYMARKET_META_SYNC_PAGE_SIZE=200

# Signals — Price Move
PRICE_MOVE_WINDOW_MINUTES=30
PRICE_MOVE_THRESHOLD_PCT=5.0

# Signals — Volume Spike
VOLUME_SPIKE_MULTIPLIER=3.0
VOLUME_SPIKE_BASELINE_HOURS=24

# Signals — Spread Change
SPREAD_CHANGE_BASELINE_HOURS=12
SPREAD_CHANGE_THRESHOLD_RATIO=2.0

# Signals — Liquidity Vacuum
LIQUIDITY_VACUUM_BASELINE_HOURS=12
LIQUIDITY_VACUUM_DEPTH_RATIO_THRESHOLD=0.3

# Signals — Deadline Near
DEADLINE_NEAR_HOURS=48
DEADLINE_NEAR_PRICE_THRESHOLD_PCT=3.0

# Evaluation
EVALUATION_INTERVAL_SECONDS=300

# Default Strategy Baseline
# Bootstrap input only. Once a strategy_run exists, this no longer rewrites the active run.
DEFAULT_STRATEGY_START_AT=2026-04-13T00:00:00+00:00

# Runtime ownership
SCHEDULER_ENABLED=false

# Alerts
ALERT_RANK_THRESHOLD=0.7
ALERT_WEBHOOK_URL=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_SIGNAL_TYPES=
ALERT_DISCORD_WEBHOOK_URL=

# Push Notifications (VAPID / Web Push)
PUSH_VAPID_PRIVATE_KEY=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_EMAIL=

# API
API_RATE_LIMIT=60/minute
API_KEY=
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:4173,http://127.0.0.1:4173

# Retention
RETENTION_PRICE_SNAPSHOTS_DAYS=30
RETENTION_ORDERBOOK_SNAPSHOTS_DAYS=14
RETENTION_SIGNALS_DAYS=90

# App
LOG_LEVEL=INFO
