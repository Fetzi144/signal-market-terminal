# Core
DATABASE_URL=postgresql+asyncpg://smt:smt@db:5432/smt
LOG_LEVEL=INFO
LOG_FORMAT=text
API_KEY=

# Research-truth profile: Polymarket-first, continuous capture, headless by default.
KALSHI_ENABLED=false
WHALE_TRACKING_ENABLED=false
WORKER_METRICS_ENABLED=true

# Keep the scanner useful without trying to host the full frontend stack.
MARKET_DISCOVERY_INTERVAL_SECONDS=300
SNAPSHOT_INTERVAL_SECONDS=120
EVALUATION_INTERVAL_SECONDS=300
ORDERBOOK_SAMPLE_SIZE=16
MIN_VOLUME_24H=5000

# Retention sized for a small but real capture box.
RETENTION_PRICE_SNAPSHOTS_DAYS=14
RETENTION_ORDERBOOK_SNAPSHOTS_DAYS=7
RETENTION_SIGNALS_DAYS=60

# Always-on Polymarket continuity profile.
POLYMARKET_STREAM_ENABLED=true
POLYMARKET_META_SYNC_ENABLED=true
POLYMARKET_RAW_STORAGE_ENABLED=true
POLYMARKET_TRADE_BACKFILL_ENABLED=true
POLYMARKET_OI_POLL_ENABLED=true
POLYMARKET_BOOK_RECON_ENABLED=true

# Research and live lanes stay off until capture continuity is proven.
POLYMARKET_FEATURES_ENABLED=false
POLYMARKET_STRUCTURE_ENGINE_ENABLED=false
POLYMARKET_RISK_GRAPH_ENABLED=false
POLYMARKET_PORTFOLIO_OPTIMIZER_ENABLED=false
POLYMARKET_REPLAY_ENABLED=false
POLYMARKET_USER_STREAM_ENABLED=false
POLYMARKET_LIVE_TRADING_ENABLED=false
POLYMARKET_PILOT_ENABLED=false
POLYMARKET_HEARTBEAT_ENABLED=false

# Capture cadence tuned for a 2 vCPU / 4 GB class box.
POLYMARKET_META_SYNC_INTERVAL_SECONDS=900
POLYMARKET_BOOK_SNAPSHOT_INTERVAL_SECONDS=300
POLYMARKET_TRADE_BACKFILL_INTERVAL_SECONDS=900
POLYMARKET_TRADE_BACKFILL_LOOKBACK_HOURS=24
POLYMARKET_OI_POLL_INTERVAL_SECONDS=900
POLYMARKET_BOOK_RECON_STALE_AFTER_SECONDS=900

# Alerts
ALERT_RANK_THRESHOLD=0.7
ALERT_WEBHOOK_URL=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_DISCORD_WEBHOOK_URL=

# Optional local API access when you start the backend profile.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
